# TicketShield Server Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Connection URI
MONGO_URI=mongodb://admin:password@localhost:27017/ticketshield?authSource=admin

# Server Port
PORT=5000

# JWT Secret Key — CHANGE THIS in production!
JWT_SECRET=ticketshield_jwt_secret_change_in_production

# Node Environment
NODE_ENV=development
